# Supabase — required for quiz session persistence.
# Create a project at https://supabase.com and copy these from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional service-role key — only used by /admin to read aggregate
# affiliate-click counts. If missing, the admin dashboard falls back to
# anon reads which won't return rows under our RLS policy. Treat this
# as a secret; never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard password. Set to any strong value. Used by the simple
# password gate at /admin and verified by middleware on /admin/* routes.
# Add the same value in your Netlify dashboard for production.
ADMIN_PASSWORD=
